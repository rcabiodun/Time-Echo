; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="time echo"
run/main_scene="uid://bb3yiklds35xj"
config/features=PackedStringArray("4.5", "Mobile")
config/icon="res://icon.svg"

[autoload]

Global="*res://scenes/global.tscn"

[display]

window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[global_group]

buttons=""
doors=""
echo=""
resettable="This are object that are  going to be glitches/resetted back to their original position  if moved or intereacted with oustide recording"
carryable="These are objects that are meant to be carried by the player"
player=""
runes=""
redirect_platform=""
projectile=""
projectile_receiver=""


boot_splash/stretch_mode=4
boot_splash/image="uid://bm21j6w068p5q"
config/icon="res://icon.svg"

[autoload]

Global="*res://scenes/global.tscn"
DeathManager="*uid://cnnp7w7kryyg8"
CameraShake="*uid://c73hrlhl6ulow"

[display]

window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

